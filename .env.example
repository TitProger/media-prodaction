# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_token_here

# ─── AI для нарезки клипов ───────────────────────────────────────────────────
# Используется один из двух (Gemini приоритет, Claude — запасной).
# Если оба не заданы — включается эвристический режим без API.
GEMINI_API_KEY=your_gemini_key_here        # бесплатно: aistudio.google.com
GEMINI_MODEL=gemini-2.0-flash-lite         # модель Gemini

ANTHROPIC_API_KEY=sk-ant-...               # платно: console.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-6             # модель Claude

# ─── REST API сервер ─────────────────────────────────────────────────────────
API_SECRET_KEY=changeme-set-in-env         # ключ для X-API-Key заголовка
API_HOST=0.0.0.0
API_PORT=8001

# ─── Нарезка клипов ──────────────────────────────────────────────────────────
CLIP_COUNT=10                              # сколько клипов искать (top_video, AI)
CLIP_MIN_DURATION=15                       # мин. длина клипа, секунд
CLIP_MAX_DURATION=60                       # макс. длина клипа, секунд
BOTTOM_CLIP_DURATION=60                    # длина куска при нарезке bottom_video

# ─── Баннер ──────────────────────────────────────────────────────────────────
# Анимация: slide_left | slide_right | fade
BANNER_ANIMATION=slide_left
BANNER_LOOP_INTERVAL=7.0                   # секунд на один цикл слайда

# ─── Whisper ─────────────────────────────────────────────────────────────────
# Размер модели: tiny | base | small | medium | large
# tiny/base — быстро, small/medium — точнее, large — максимум качества
WHISPER_MODEL=base
# WHISPER_LANGUAGE=ru                      # раскомментировать для фиксации языка
